;   double (*matrix)[cols] = (double (*)[cols]) conf->matrix;
;   const int N = 4;
;   double results[N];
;   #pragma oss taskwait in(results[3])
;   return 0.0;
; }

%struct.HeatConfiguration = type { i32, i32, double, double, i64, i64, i32, i32, i32, ptr, i32, ptr, [4096 x i8], [4096 x i8], i8, i8, i8 }
%struct._depend_unpack_t = type { ptr, i64, i64, i64 }

; Function Attrs: nounwind uwtable
define hidden double @solve() !dbg !6 {
entry:
  %vla = alloca double, i64 4, align 16, !dbg !32
  %1 = call token @llvm.directive.region.entry() [ "DIR.OSS"([5 x i8] c"TASK\00"), "QUAL.OSS.SHARED"(ptr %vla, double undef), "QUAL.OSS.VLA.DIMS"(ptr %vla, i64 4), "QUAL.OSS.CAPTURED"(i64 4) ], !dbg !33
  call void @llvm.directive.region.exit(token %1), !dbg !33
  ret double 0.000000e+00, !dbg !34
}

