; CodeExtractor asserts when iterating oven Constants
; in fixupDebugInfoPostExtraction. This happens
; because in OmpSs-2 we pass Constants, and we
; shouldn't
; #include <string.h>
; #include <stdio.h>
; #include "heat.h"
; double solve(HeatConfiguration *conf, int64_t rows, int64_t cols, int timesteps, void *extraData)
